  "components": {
    "schemas": {
      "ClusterHealth": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "clusterName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "green",
              "yellow",
              "red"
            ]
          },
          "numberOfNodes": {
            "type": "integer"
          },
          "numberOfDataNodes": {
